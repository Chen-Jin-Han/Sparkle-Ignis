# Copy this file to .env.sparkle and fill in your own key locally.
# Never commit real API keys.

SPARKLE_PORT=8080

# Set this to true when you want Sparkle to call DeepSeek for report polishing.
SPARKLE_USE_DEEPSEEK=false

# DeepSeek official OpenAI-compatible endpoint.
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=60

# Put your DeepSeek API key here in .env.sparkle only.
DEEPSEEK_API_KEY=
